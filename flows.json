    {
        "id": "simulador-dirigido",
        "type": "function",
        "z": "003c4fb1a3e749fb",
        "name": "Simulador (Movimiento hacia Destino)",
        "func": "let buses = global.get(\"buses\");\nlet destinoId = global.get(\"destinoActual\");\nlet paradas = global.get(\"paradas\");\n\nif (!buses || !paradas) return null;\nlet destino = paradas.find(p => p.id === destinoId);\nif (!destino) return null;\n\n// Matemáticas vectoriales para apuntar la dirección hacia el destino elegido\nbuses.forEach(bus => {\n    let dLat = destino.lat - bus.lat;\n    let dLon = destino.lon - bus.lon;\n    let dist = Math.sqrt(dLat*dLat + dLon*dLon);\n    \n    // Si el bus está a más de 50 metros del objetivo, avanza. \n    // Si llegó, se detiene automáticamente en la parada.\n    if (dist > 0.0005) {\n        let ratio = 0.0005 / dist; // Velocidad de simulación por ciclo\n        bus.lat += dLat * ratio;\n        bus.lon += dLon * ratio;\n    }\n});\nglobal.set(\"buses\", buses);\n\n// Retornar mensajes empaquetados para el nodo worldmap\nlet cmds = buses.map(bus => ({\n    payload: {\n        name: bus.name,\n        lat: bus.lat,\n        lon: bus.lon,\n        icon: \"bus\",\n        iconColor: \"blue\",\n        layer: \"Buses\"\n    }\n}));\nreturn [cmds];",
        "outputs": 1,
        "x": 430,
        "y": 600,
        "wires": [
            [
                "calc-eta"
            ]
        ]
    },
    {
        "id": "calc-eta",
        "type": "function",
        "z": "003c4fb1a3e749fb",
        "name": "Recálculo de ETA y Trazado de Rutas",
        "func": "let buses = global.get(\"buses\");\nlet destinoId = global.get(\"destinoActual\");\nlet paradas = global.get(\"paradas\");\n\nif (!buses || !paradas) return null;\nlet destino = paradas.find(p => p.id === destinoId);\n\n// Algoritmo Haversine\nfunction haversine(lat1, lon1, lat2, lon2) {\n    const R = 6371;\n    const dLat = (lat2 - lat1) * Math.PI / 180;\n    const dLon = (lon2 - lon1) * Math.PI / 180;\n    const a = Math.sin(dLat/2) * Math.sin(dLat/2) +\n              Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *\n              Math.sin(dLon/2) * Math.sin(dLon/2);\n    return R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a)));\n}\n\nlet tablaETA = [];\nlet lineasMapa = [];\n\nbuses.forEach(bus => {\n    let distKm = haversine(bus.lat, bus.lon, destino.lat, destino.lon);\n    let timeHours = distKm / bus.speed;\n    let etaMin = Math.round(timeHours * 60);\n    \n    // Preparar objeto para el ui-table de Dashboard 2.0\n    tablaETA.push({\n        Unidad: bus.name,\n        Distancia: distKm.toFixed(2) + \" km\",\n        ETA: (etaMin === 0) ? \"Llegando\" : etaMin + \" min\",\n        Destino: destino.nombre\n    });\n\n    // Preparar objeto para dibujar la línea predictiva en worldmap\n    lineasMapa.push({\n        payload: {\n            name: \"Ruta-\" + bus.name,\n            line: [ [bus.lat, bus.lon], [destino.lat, destino.lon] ],\n            color: \"#E53E3E\",\n            weight: 3,\n            layer: \"Rutas Predictivas\"\n        }\n    });\n});\n\nglobal.set(\"busesConETA\", tablaETA);\n\n// Salida 1: Matriz para el ui-table | Salida 2: Comandos de línea para worldmap\nreturn [{ payload: tablaETA }, lineasMapa];",
        "outputs": 2,
        "x": 790,
        "y": 600,
        "wires": [
            [],
            []
        ]
    }
]