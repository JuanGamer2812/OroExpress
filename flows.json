            ]
        ]
    },
    {
        "id": "function-telemetria",
        "type": "function",
        "z": "003c4fb1a3e749fb",
        "name": "Simulador GPS y cálculo de ETA",
        "func": "// Inicializar el índice de la ruta si no existe\nif (context.get('index') === undefined) {\n    context.set('index', 0);\n}\n\n// Ruta simplificada desde la Terminal Terrestre de Machala hasta Santa Rosa\nconst ruta = [\n    { lat: -3.2581, lon: -79.9553, stop: \"Terminal Terrestre de Machala\" },\n    { lat: -3.2845, lon: -79.9612, stop: \"Control de Entrada - El Cambio\" },\n    { lat: -3.3210, lon: -79.9645, stop: \"Vía Panamericana - Km 10\" },\n    { lat: -3.3650, lon: -79.9680, stop: \"Peaje El Guabo / Bifurcación\" },\n    { lat: -3.4120, lon: -79.9650, stop: \"Entrada a Santa Rosa\" },\n    { lat: -3.4480, lon: -79.9610, stop: \"Av. Joffre Lima\" },\n    { lat: -3.4578, lon: -79.9654, stop: \"Terminal Terrestre de Santa Rosa\" }\n];\n\nlet idx = context.get('index');\nlet puntoActual = ruta[idx];\n\n// Cálculo de tiempo estimado de llegada (ETA) aproximado\n// Cada segmento simulado representa unos 4 minutos reales de viaje restante\nlet segmentosRestantes = (ruta.length - 1) - idx;\nlet etaMinutos = segmentosRestantes * 4;\nlet etaStr = etaMinutos === 0 ? \"Ha llegado a su destino\" : etaMinutos + \" min\";\n\n// Generar velocidad simulada con fluctuación\nlet velocidadSimulada = etaMinutos === 0 ? 0 : Math.floor(Math.random() * (65 - 42 + 1)) + 42;\n\n// Construir el payload de telemetría IoT\nmsg.payload = {\n    busId: \"COOP-ORO-04\",\n    lat: puntoActual.lat,\n    lon: puntoActual.lon,\n    velocidad: velocidadSimulada + \" km/h\",\n    eta: etaStr,\n    proximaParada: idx === ruta.length - 1 ? \"Fin del trayecto\" : ruta[idx + 1].stop,\n    paradaActual: puntoActual.stop\n};\n\n// Avanzar en la ruta o reiniciar si llega al final\nidx = (idx + 1) % ruta.length;\ncontext.set('index', idx);\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 610,
        "y": 400,
        "wires": [
            [
                "ui-template-mapa",
                "ui-text-bus",
                "ui-text-eta",
