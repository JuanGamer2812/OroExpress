    {
        "id": "d7d3c62bca1474a9",
        "type": "function",
        "z": "003c4fb1a3e749fb",
        "name": "Simulador de 5 salidas",
        "func": "if (context.get('index') === undefined) {\n    context.set('index', 0);\n}\n\nconst ruta = [\n    { lat: -3.2581, lon: -79.9553, stop: \"Terminal Terrestre de Machala\" },\n    { lat: -3.2845, lon: -79.9612, stop: \"Control de Entrada - El Cambio\" },\n    { lat: -3.3210, lon: -79.9645, stop: \"Vía Panamericana - Km 10\" },\n    { lat: -3.3650, lon: -79.9680, stop: \"Peaje El Guabo / Bifurcación\" },\n    { lat: -3.4120, lon: -79.9650, stop: \"Entrada a Santa Rosa\" },\n    { lat: -3.4480, lon: -79.9610, stop: \"Av. Joffre Lima\" },\n    { lat: -3.4578, lon: -79.9654, stop: \"Terminal Terrestre de Santa Rosa\" }\n];\n\nlet idx = context.get('index');\nlet puntoActual = ruta[idx];\n\nlet segmentosRestantes = (ruta.length - 1) - idx;\nlet etaMinutos = segmentosRestantes * 4;\nlet etaStr = etaMinutos === 0 ? \"Ha llegado a su destino\" : etaMinutos + \" min\";\nlet velocidadSimulada = etaMinutos === 0 ? 0 : Math.floor(Math.random() * (65 - 42 + 1)) + 42;\n\nlet payloadObj = {\n    busId: \"COOP-ORO-04\",\n    lat: puntoActual.lat,\n    lon: puntoActual.lon,\n    velocidad: velocidadSimulada + \" km/h\",\n    eta: etaStr,\n    proximaParada: idx === ruta.length - 1 ? \"Fin del trayecto\" : ruta[idx + 1].stop,\n    paradaActual: puntoActual.stop\n};\n\nidx = (idx + 1) % ruta.length;\ncontext.set('index', idx);\n\n// Retornar 5 mensajes separados para cada nodo, así evitamos [object Object]\nreturn [\n    { payload: payloadObj },\n    { payload: payloadObj.busId },\n    { payload: payloadObj.eta },\n    { payload: payloadObj.velocidad },\n    { payload: payloadObj.proximaParada }\n];",
        "outputs": 5,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 360,
        "wires": [
            [
                "8198530f7faf0933"
            ],
