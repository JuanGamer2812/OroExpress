    {
        "id": "inject-simulador",
        "type": "inject",
        "z": "003c4fb1a3e749fb",
        "name": "Disparador (Cada 3s)",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "3",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",
