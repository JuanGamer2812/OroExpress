    {
        "id": "ui-template-mapa",
        "type": "ui-template",
        "z": "003c4fb1a3e749fb",
        "group": "ui-group-mapa",
        "name": "Mapa Leaflet interactivo",
        "order": 1,
        "width": 0,
        "height": 0,
        "format": "<template>\n    <div style=\"padding: 10px;\">\n        <div id=\"leaflet-map-transit\" style=\"height: 480px; width: 100%; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);\"></div>\n    </div>\n</template>\n\n<script>\nexport default {\n    name: 'LeafletTransitMap',\n    data() {\n        return {\n            map: null,\n            marker: null,\n            polyline: null,\n            // Coordenadas fijas de la ruta completa para pintar la línea base\n            rutaFija: [\n                [-3.2581, -79.9553],\n                [-3.2845, -79.9612],\n                [-3.3210, -79.9645],\n                [-3.3650, -79.9680],\n                [-3.4120, -79.9650],\n                [-3.4480, -79.9610],\n                [-3.4578, -79.9654]\n            ]\n        }\n    },\n    mounted() {\n        // Inyectar dinámicamente estilos CSS de Leaflet si no están en el documento\n        if (!document.getElementById('leaflet-css')) {\n            const link = document.createElement('link');\n            link.id = 'leaflet-css';\n            link.rel = 'stylesheet';\n            link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';\n            document.head.appendChild(link);\n        }\n\n        // Inyectar script JS de Leaflet si no está cargado\n        if (typeof L === 'undefined') {\n            const script = document.createElement('script');\n            script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';\n            script.onload = () => {\n                this.initMap();\n            };\n            document.head.appendChild(script);\n        } else {\n            this.initMap();\n        }\n    },\n    methods: {\n        initMap() {\n            // Inicializar mapa centrado entre Machala y Santa Rosa\n            this.map = L.map('leaflet-map-transit').setView([-3.35, -79.96], 11);\n            \n            // Capa base de OpenStreetMap de diseño limpio\n            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {\n                attribution: '© OpenStreetMap'\n            }).addTo(this.map);\n\n            // Dibujar la trayectoria completa en color gris/azul para diseño refinado\n            this.polyline = L.polyline(this.rutaFija, {\n                color: '#4A5568',\n                weight: 4,\n                opacity: 0.6,\n                dashArray: '5, 10'\n            }).addTo(this.map);\n\n            // Inicializar el marcador del autobús (posición Machala por defecto)\n            this.marker = L.marker([-3.2581, -79.9553]).addTo(this.map);\n            this.marker.bindPopup(\"<b>Esperando datos de telemetría...</b>\").openPopup();\n        }\n    },\n    watch: {\n        // En Dashboard 2.0, vigilamos la propiedad reactiva 'msg' que Node-RED inyecta automáticamente\n        msg: {\n            handler(newMsg) {\n                if (newMsg && newMsg.payload && this.map && this.marker) {\n                    const data = newMsg.payload;\n                    if (data.lat && data.lon) {\n                        const nuevaPos = [data.lat, data.lon];\n                        \n                        // Actualizar marcador con animación suave o directa\n                        this.marker.setLatLng(nuevaPos);\n                        \n                        // Centrar suavemente el mapa en el bus en movimiento\n                        this.map.panTo(nuevaPos);\n                        \n                        // Actualizar globo de información dinámica con FontAwesome integrado\n                        const popupContent = `\n                            <div style=\"font-family: sans-serif; font-size: 13px;\">\n                                <strong style=\"color:#2B6CB0;\"><i class=\"fa fa-bus\"></i> Unid: ${data.busId}</strong><br>\n                                <b>Estado:</b> ${data.paradaActual}<br>\n                                <b>Velocidad:</b> ${data.velocidad}<br>\n                                <b style=\"color:#E53E3E;\">ETA: ${data.eta}</b>\n                            </div>\n                        `;\n                        this.marker.bindPopup(popupContent).openPopup();\n                    }\n                }\n            },\n            deep: True\n        }\n    }\n}\n</script>",
        "templateScope": "local",
        "className": "",
        "x": 900,
        "y": 300,
        "wires": [
            []
        ]
