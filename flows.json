        "type": "function",
        "z": "003c4fb1a3e749fb",
        "name": "Definir Variables Globales",
        "func": "const paradas = [\n    { id: \"term\", nombre: \"Terminal Terrestre Binacional\", lat: -3.4611, lon: -79.9680 },\n    { id: \"parq\", nombre: \"Parque Sucre (Centro)\", lat: -3.4522, lon: -79.9616 },\n    { id: \"hosp\", nombre: \"Hospital Santa Teresita\", lat: -3.4540, lon: -79.9570 },\n    { id: \"merc\", nombre: \"Mercado Central\", lat: -3.4505, lon: -79.9600 },\n    { id: \"muni\", nombre: \"Municipio de Santa Rosa\", lat: -3.4518, lon: -79.9612 },\n    { id: \"cole\", nombre: \"Colegio Zoila Ugarte\", lat: -3.4560, lon: -79.9645 },\n    { id: \"bomb\", nombre: \"Cuerpo de Bomberos\", lat: -3.4485, lon: -79.9585 },\n    { id: \"aero\", nombre: \"Aeropuerto Regional\", lat: -3.4380, lon: -79.9750 }\n];\n\nglobal.set(\"paradas\", paradas);\nglobal.set(\"destinoActual\", \"term\"); // Destino por defecto al arrancar\n\n// Posiciones iniciales esparcidas en Santa Rosa\nconst buses = [\n    { id: \"B1\", name: \"COOP-ORO-01\", lat: -3.4380, lon: -79.9750, speed: 45 },\n    { id: \"B2\", name: \"COOP-ORO-02\", lat: -3.4505, lon: -79.9600, speed: 50 }\n];\nglobal.set(\"buses\", buses);\nreturn msg;",
